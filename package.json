{
  "name": "examplehr-time-off-service",
  "version": "1.0.0",
  "description": "ExampleHR Time-Off Microservice with HCM sync",
  "private": true,
  "scripts": {
    "build": "nest build time-off-service && nest build mock-hcm",
    "build:time-off": "nest build time-off-service",
    "build:mock-hcm": "nest build mock-hcm",
    "start": "nest start time-off-service",
    "start:dev": "nest start time-off-service --watch",
    "start:mock-hcm": "nest start mock-hcm",
    "start:mock-hcm:dev": "nest start mock-hcm --watch",
    "start:all": "concurrently \"npm:start:mock-hcm:dev\" \"npm:start:dev\"",
    "lint": "eslint \"{apps,test}/**/*.ts\" --fix",
    "format": "prettier --write \"apps/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:scenarios": "jest --testPathPattern=scenarios",
    "test:unit": "jest --testPathPattern=\"(unit|spec\\.ts$)\" --testPathIgnorePatterns=scenarios"
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.2",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/typeorm": "^10.0.2",
    "axios": "^1.7.2",
    "axios-retry": "^4.4.2",
    "better-sqlite3": "^11.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.2",
    "@nestjs/testing": "^10.3.10",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "apps/**/*.(t|j)s",
      "!apps/**/main.ts",
      "!apps/**/*.module.ts",
      "!apps/**/*.dto.ts",
      "!apps/**/*.entity.ts",
      "!apps/**/index.ts"
    ],
    "coverageDirectory": "./coverage",
    "coverageReporters": ["text", "text-summary", "lcov", "json-summary", "html"],
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@time-off/(.*)$": "<rootDir>/apps/time-off-service/src/$1",
      "^@mock-hcm/(.*)$": "<rootDir>/apps/mock-hcm/src/$1"
    },
    "testTimeout": 20000
  }
}
