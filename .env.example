# Time-Off Service
PORT=3000
DATABASE_PATH=./data/time-off.sqlite
HCM_BASE_URL=http://localhost:4000
HCM_REQUEST_TIMEOUT_MS=5000
HCM_MAX_RETRIES=3
OUTBOX_WORKER_INTERVAL_MS=2000
OUTBOX_MAX_ATTEMPTS=8
NODE_ENV=development
LOG_LEVEL=info

# Mock HCM
MOCK_HCM_PORT=4000
MOCK_HCM_DB_PATH=./data/mock-hcm.sqlite
